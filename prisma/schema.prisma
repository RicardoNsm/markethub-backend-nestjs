generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
    id String @id @default(uuid())
    name String
    email String
    password String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

